<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <Toolbar class="jhahToolHeader" height="3.25rem" visible="{= !${dashboard>/isEmbedFrame} }">
        <core:Icon src="sap-icon://grid" class="jhahHeaderIcon sapUiSmallMarginBegin" />
        <Title
            text="{dashboard>/pageTitle}"
            level="H4"
            class="jhahPageTitle sapUiSmallMarginBegin"
        />
        <ToolbarSpacer />
        <Button icon="sap-icon://bell-notification" type="Transparent" class="jhahHeaderIcon" />
        <Button icon="sap-icon://download-from-cloud" type="Transparent" class="jhahHeaderIcon sapUiSmallMarginEnd" />
    </Toolbar>
</core:FragmentDefinition>
