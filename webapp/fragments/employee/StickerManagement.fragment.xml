<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
>
    <VBox class="jhahSection" renderType="Bare">
        <Title text="Sticker Management" level="H5" class="jhahSectionTitle" />
        <HBox class="jhahTwoColRow" renderType="Bare" alignItems="Stretch" width="100%">
            <!-- Active Sticker card -->
            <VBox class="jhahHalfCardWrap" renderType="Bare">
                <layoutData>
                    <FlexItemData growFactor="1" baseSize="0%" />
                </layoutData>
                <f:Card class="jhahDataCard" width="100%">
                    <f:content>
                        <VBox class="jhahPairCardInner" renderType="Bare" justifyContent="Start" width="100%">
                            <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiSmallMarginBottom">
                                <Label text="ACTIVE STICKER" class="jhahMutedText" />
                                <ObjectStatus text="{dashboard>/sticker/status}" state="Success" icon="sap-icon://status-positive" />
                            </HBox>
                            <Title text="{dashboard>/sticker/plate}" level="H2" class="jhahHighlightValue" />
                            <Text text="{dashboard>/sticker/vehicle}" class="jhahMutedText" />
                            <HBox class="sapUiSmallMarginTop" alignItems="Center">
                                <Label text="Expires:" class="jhahMutedText sapUiTinyMarginEnd" />
                                <Text text="{dashboard>/sticker/expiry}" />
                            </HBox>
                        </VBox>
                    </f:content>
                </f:Card>
            </VBox>
            <!-- Request Status card -->
            <VBox class="jhahHalfCardWrap" renderType="Bare" width="100%">
                <layoutData>
                    <FlexItemData growFactor="1" baseSize="0%" />
                </layoutData>
                <f:Card class="jhahDataCard" width="100%">
                    <f:content>
                        <VBox class="jhahPairCardInner" renderType="Bare" justifyContent="Start" width="100%">
                            <Title text="Request Status" level="H6" class="sapUiSmallMarginBottom" />
                            <Table
                                items="{dashboard>/sticker/requests}"
                                showSeparators="Inner"
                                class="jhahInnerTable"
                                fixedLayout="false"
                            >
                                <columns>
                                    <Column><Text text="Request No" /></Column>
                                    <Column><Text text="Expiry" /></Column>
                                    <Column hAlign="End"><Text text="Status" /></Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Link text="{dashboard>requestNo}" />
                                            <Text text="{dashboard>expiry}" />
                                            <ObjectStatus
                                                text="{dashboard>status}"
                                                state="{dashboard>statusState}"
                                            />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </VBox>
                    </f:content>
                </f:Card>
            </VBox>
        </HBox>
    </VBox>
</core:FragmentDefinition>
