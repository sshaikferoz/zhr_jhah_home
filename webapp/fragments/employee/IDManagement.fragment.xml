<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
>
    <VBox class="jhahSection" renderType="Bare">
        <Title text="ID Management System" level="H5" class="jhahSectionTitle" />
        <HBox class="jhahTwoColRow" renderType="Bare" alignItems="Stretch" width="100%">
            <!-- Badge ID card -->
            <VBox class="jhahHalfCardWrap" renderType="Bare">
                <layoutData>
                    <FlexItemData growFactor="1" baseSize="0%" />
                </layoutData>
                <f:Card class="jhahDataCard" width="100%">
                    <f:content>
                        <VBox class="jhahPairCardInner" renderType="Bare" justifyContent="Start">
                            <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiSmallMarginBottom">
                                <Label text="BADGE ID" class="jhahMutedText" />
                                <ObjectStatus text="Active" state="Success" icon="sap-icon://status-positive" />
                            </HBox>
                            <Title text="{dashboard>/idCard/badgeId}" level="H2" class="jhahHighlightValue" />
                            <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiTinyMarginTop">
                                <Label text="Days until Expiration" class="jhahMutedText" />
                                <Text text="{dashboard>/idCard/daysUntilExpiry}" class="jhahHighlightValue" />
                            </HBox>
                            <ProgressIndicator
                                percentValue="{dashboard>/idCard/expiryPercent}"
                                showValue="false"
                                state="None"
                                class="jhahExpiryProgress"
                                height="0.5rem"
                            />
                            <HBox class="sapUiTinyMarginTop" alignItems="Center">
                                <Label text="JHAH ID:" class="jhahMutedText sapUiTinyMarginEnd" />
                                <Text text="{dashboard>/idCard/jhahId}" />
                            </HBox>
                        </VBox>
                    </f:content>
                </f:Card>
            </VBox>
            <!-- In Progress Request card -->
            <VBox class="jhahHalfCardWrap" renderType="Bare">
                <layoutData>
                    <FlexItemData growFactor="1" baseSize="0%" />
                </layoutData>
                <f:Card class="jhahDataCard" width="100%">
                    <f:content>
                        <VBox class="jhahPairCardInner" renderType="Bare" justifyContent="Start">
                            <Label text="IN PROGRESS REQUEST" class="jhahMutedText sapUiSmallMarginBottom" />
                            <Title text="{dashboard>/idCard/inProgressId}" level="H2" />
                            <Text text="{dashboard>/idCard/inProgressType}" class="jhahMutedText" />
                        </VBox>
                    </f:content>
                </f:Card>
            </VBox>
        </HBox>
    </VBox>
</core:FragmentDefinition>
