<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
>
    <VBox class="jhahSection jhahViolationsSection" renderType="Bare" height="100%">
        <Title text="Traffic Violation System" level="H5" class="jhahSectionTitle" />
        <HBox class="jhahKpiRow" renderType="Bare" wrap="Wrap">
            <!-- Active Violations -->
            <f:Card class="jhahAlertCard jhahAlertCardError jhahHalfCard">
                <f:content>
                    <HBox alignItems="Start" class="jhahAlertCardInner">
                        <VBox renderType="Bare" class="jhahAlertCardText">
                            <Label text="Active Violations" class="jhahKpiTitle" />
                            <ObjectNumber
                                number="{dashboard>/violations/active}"
                                emphasized="true"
                                class="jhahAlertNumber"
                            />
                            <Text
                                text="Requires immediate disciplinary action"
                                class="jhahMutedText"
                            />
                        </VBox>
                        <core:Icon src="sap-icon://warning2" class="jhahAlertIcon jhahIconError" />
                    </HBox>
                </f:content>
            </f:Card>
            <!-- Year to Date Violations -->
            <f:Card class="jhahAlertCard jhahAlertCardInfo jhahHalfCard">
                <f:content>
                    <HBox alignItems="Start" class="jhahAlertCardInner">
                        <VBox renderType="Bare" class="jhahAlertCardText">
                            <Label text="Year to date Violations" class="jhahKpiTitle" />
                            <ObjectNumber
                                number="{dashboard>/violations/ytd}"
                                emphasized="true"
                                class="jhahAlertNumber jhahAlertNumberInfo"
                            />
                            <Text
                                text="Requires immediate disciplinary action"
                                class="jhahMutedText"
                            />
                        </VBox>
                        <core:Icon src="sap-icon://warning2" class="jhahAlertIcon jhahIconInfo" />
                    </HBox>
                </f:content>
            </f:Card>
        </HBox>
            <!-- Violations Points -->
            <f:Card class="jhahDataCard jhahStackedCard jhahViolationsPointsCard">
                <f:content>
                    <VBox class="jhahPairCardInner" renderType="Bare" width="100%">
                        <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiSmallMarginBottom">
                            <Title text="Current Violations Points" level="H6" />
                            <ObjectStatus text="2 Active" state="Error" />
                        </HBox>
                        <HBox justifyContent="SpaceBetween" alignItems="End" class="sapUiSmallMarginBottom">
                            <VBox renderType="Bare">
                                <Label text="Total Points" class="jhahMutedText" />
                                <ObjectNumber
                                    number="{dashboard>/violations/totalPoints}"
                                    unit="pts"
                                    emphasized="true"
                                    state="Error"
                                />
                            </VBox>
                            <VBox renderType="Bare" class="jhahAlignEnd">
                                <Label text="Last Violation" class="jhahMutedText" />
                                <Text text="{dashboard>/violations/lastViolation}" />
                            </VBox>
                        </HBox>
                        <MessageStrip
                            text="{dashboard>/violations/alertMessage}"
                            type="Error"
                            showIcon="true"
                            showCloseButton="false"
                        />
                    </VBox>
                </f:content>
            </f:Card>
    </VBox>
</core:FragmentDefinition>
