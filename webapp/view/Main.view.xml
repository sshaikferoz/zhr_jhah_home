<mvc:View
    controllerName="com.jhah.zhrjhahhome.controller.Main"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    displayBlock="true"
    height="100%"
>
    <HBox class="jhahAppShell" renderType="Bare" fitContainer="true" height="100%">
        <core:Fragment
            fragmentName="com.jhah.zhrjhahhome.fragments.common.SideNavigation"
            type="XML"
        />
        <VBox class="jhahMainColumn" renderType="Bare" height="100%" fitContainer="true">
            <core:Fragment
                fragmentName="com.jhah.zhrjhahhome.fragments.common.Header"
                type="XML"
            />
            <ScrollContainer
                width="100%"
                vertical="true"
                horizontal="false"
                class="{= 'jhahMainScroll' + (${dashboard>/isEmbedFrame} ? ' jhahMainScrollEmbed' : '') }"
            >
                <layoutData>
                    <FlexItemData growFactor="1" baseSize="0%" />
                </layoutData>
                <VBox
                    id="dashboardContent"
                    class="{= 'jhahDashboardContent' + (${dashboard>/isEmbedFrame} ? ' jhahDashboardContentEmbed' : '') }"
                    renderType="Bare"
                    width="100%"
                />
            </ScrollContainer>
        </VBox>
    </HBox>
</mvc:View>
